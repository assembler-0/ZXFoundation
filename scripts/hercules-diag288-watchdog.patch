     /* Diagnose 288: Control Virtual Machine Time Bomb               */
+    /*                                                               */
+    /* Used by Linux watchdog (drivers/watchdog/diag288_wdt.c)       */
+    /* to set/change/cancel a watchdog timer.  On expiry the system  */
+    /* is restarted (IPL from the boot device).                      */
+    /*                                                               */
+    /* R1 even = function code (0=INIT, 1=CHANGE, 2=CANCEL)         */
+    /* R1 odd  = timeout in seconds                                  */
+    /* R3 even = action (0=LPAR restart, or CP cmd addr for VM)      */
+    /* R3 odd  = CP cmd length for VM, 0 for LPAR                    */
     /*---------------------------------------------------------------*/
-        regs->psw.cc = ARCH_DEP(vm_timebomb) (r1, r3, regs);
+    {
+        U64 func    = regs->GR(r1);
+        U64 timeout = regs->GR(r1 + 1);
+
+        switch (func) {
+        case 0:  /* WDT_FUNC_INIT  */
+        case 1:  /* WDT_FUNC_CHANGE */
+            if (timeout < 1)
+            {
+                ARCH_DEP(program_interrupt)(regs,
+                        PGM_SPECIFICATION_EXCEPTION);
+                break;
+            }
+            _wdt_expiry = time(NULL) + (time_t)timeout;
+            if (!_wdt_tid)
+                create_thread(&_wdt_tid, DETACHED,
+                        _wdt_thread, NULL, "wdt_ipl");
+            regs->psw.cc = 0;
+            break;
+
+        case 2:  /* WDT_FUNC_CANCEL */
+            _wdt_expiry = 0;
+            regs->psw.cc = 0;
+            break;
+
+        default:
+            ARCH_DEP(program_interrupt)(regs,
+                    PGM_SPECIFICATION_EXCEPTION);
+            break;
+        }
         break;
