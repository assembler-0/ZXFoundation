--- a/diagnose.c
+++ b/diagnose.c
@@ -183,6 +183,64 @@ struct ipl_parameter_block {
 #define DIAG308_RC_OK        0x0001
 #define DIAG308_RC_NOCONFIG  0x0102
 
+/*-------------------------------------------------------------------*/
+/* DIAG X'288' watchdog state and helper thread.                     */
+/*-------------------------------------------------------------------*/
+static volatile time_t _wdt_expiry = 0;  /* 0 = not armed            */
+static TID            _wdt_tid    = 0;   /* Worker thread ID         */
+
+static void* _wdt_thread(void* arg)
+{
+    UNREFERENCED(arg);
+
+    LOG_THREAD_BEGIN("wdt_ipl");
+
+    while (1)
+    {
+        SLEEP(1);
+
+        if (_wdt_expiry == 0)
+            break;  /* cancelled */
+
+        if (time(NULL) >= _wdt_expiry)
+        {
+            char iplcmd[64];
+
+            _wdt_expiry = 0;
+
+            logmsg("DIAG X'288' watchdog timer expired\n");
+
+            panel_command("stopall");
+
+            while (1)
+            {
+                int i, all_stopped = 1;
+                OBTAIN_INTLOCK(NULL);
+                for (i = 0; i < sysblk.hicpu; i++)
+                {
+                    if (IS_CPU_ONLINE(i)
+                        && sysblk.regs[i]->cpustate != CPUSTATE_STOPPED)
+                    {
+                        all_stopped = 0;
+                        break;
+                    }
+                }
+                RELEASE_INTLOCK(NULL);
+                if (all_stopped) break;
+                SLEEP(1);
+            }
+
+            sprintf(iplcmd, "ipl %03X", sysblk.ipldev);
+            panel_command(iplcmd);
+            break;
+        }
+    }
+
+    _wdt_tid = 0;
+    LOG_THREAD_END("wdt_ipl");
+    return NULL;
+}
+
 #endif // COMPILE_THIS_ONLY_ONCE
 
 #ifndef STOP_CPUS_AND_IPL
