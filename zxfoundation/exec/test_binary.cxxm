/// SPDX-License-Identifier: Apache-2.0
/// @file zxfoundation/exec/test_binary.cxxm
/// @brief Embedded minimal s390x ELF64 test binary for validating user-mode entry.
///
/// This module provides a hand-crafted minimal ELF binary that:
///   1. Writes "Hello from user domain!\n" via SVC 21 (console_write)
///   2. Exits via SVC 2 (domain_exit)
///
/// The binary is a statically-linked s390x executable at load address 0x400000.
/// It uses big-endian byte order (native s390x).
///
/// Nucleus call convention:
///   SVC 21 (console_write): r2 = buffer pointer, r3 = length
///   SVC 2  (domain_exit):   r2 = exit code (unused)

export module zxfoundation.exec.test_binary;
import zxfoundation.base.types;

namespace _internal {

    //
    // Hand-assembled s390x ELF64 test binary.
    //
    // Virtual load address: 0x0000'0000'0040'0000 (4 MiB)
    //
    // Code section (.text) at file offset 0x78 (after ELF header + 1 PHDR):
    //
    //   0x400078:  c0 20 00 00 00 0b    larl  %r2, msg       # r2 = &msg (0x40008e)
    //   0x40007e:  a7 39 00 18          lghi  %r3, 24        # r3 = length
    //   0x400082:  0a 15                svc   21             # console_write(buf=r2, len=r3)
    //   0x400084:  a7 29 00 00          lghi  %r2, 0         # exit code
    //   0x400088:  0a 02                svc   2              # domain_exit
    //   0x40008a:  a7 f4 ff ff          j     .              # spin (unreachable)
    //
    // Data section (msg) at file offset 0x8e (vaddr 0x40008e):
    //   "Hello from user domain!\n" (24 bytes)
    //
    // LARL displacement calculation:
    //   PC = 0x400078, target = 0x40008e
    //   halfword offset = (0x40008e - 0x400078) / 2 = 0x16 / 2 = 0x0B
    //
    // Total binary size: 166 bytes (0xA6)

    static constexpr u8 g_test_elf[] = {
        // ── ELF Header (64 bytes) ────────────────────────────────────
        0x7f, 0x45, 0x4c, 0x46,  // e_ident[0..3]: magic
        0x02,                    // e_ident[4]: ELFCLASS64
        0x02,                    // e_ident[5]: ELFDATA2MSB
        0x01,                    // e_ident[6]: EV_CURRENT
        0x00,                    // e_ident[7]: ELFOSABI_NONE
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, // pad

        0x00, 0x02,              // e_type: ET_EXEC
        0x00, 0x16,              // e_machine: EM_S390
        0x00, 0x00, 0x00, 0x01,  // e_version: 1

        // e_entry: 0x0000000000400078
        0x00, 0x00, 0x00, 0x00, 0x00, 0x40, 0x00, 0x78,

        // e_phoff: 0x0000000000000040 (64)
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x40,

        // e_shoff: 0x0000000000000000 (no sections)
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,

        0x00, 0x00, 0x00, 0x00,  // e_flags: 0
        0x00, 0x40,              // e_ehsize: 64
        0x00, 0x38,              // e_phentsize: 56
        0x00, 0x01,              // e_phnum: 1
        0x00, 0x40,              // e_shentsize: 64
        0x00, 0x00,              // e_shnum: 0
        0x00, 0x00,              // e_shstrndx: 0

        // ── Program Header (56 bytes at offset 0x40) ─────────────────
        0x00, 0x00, 0x00, 0x01,  // p_type: PT_LOAD

        0x00, 0x00, 0x00, 0x07,  // p_flags: PF_R|PF_W|PF_X

        // p_offset: 0
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,

        // p_vaddr: 0x400000
        0x00, 0x00, 0x00, 0x00, 0x00, 0x40, 0x00, 0x00,

        // p_paddr: 0x400000
        0x00, 0x00, 0x00, 0x00, 0x00, 0x40, 0x00, 0x00,

        // p_filesz: 0xA6 (166)
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xA6,

        // p_memsz: 0xA6 (166)
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xA6,

        // p_align: 0x1000 (4096)
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x10, 0x00,

        // ── Code (at file offset 0x78 = 120, vaddr 0x400078) ────────

        // larl %r2, msg        → c0 20 00 00 00 0B
        // r2 = buffer pointer for nc_write
        0xc0, 0x20, 0x00, 0x00, 0x00, 0x0B,

        // lghi %r3, 24         → a7 39 00 18
        // r3 = length for nc_write
        0xa7, 0x39, 0x00, 0x18,

        // svc 21               → 0a 15  (console_write)
        0x0a, 0x15,

        // lghi %r2, 0          → a7 29 00 00  (exit code)
        0xa7, 0x29, 0x00, 0x00,

        // svc 2                → 0a 02  (domain_exit)
        0x0a, 0x02,

        // j .                  → a7 f4 ff ff  (infinite loop, unreachable)
        0xa7, 0xf4, 0xff, 0xff,

        // ── Data: "Hello from user domain!\n" (24 bytes at offset 0x8e) ──
        0x48, 0x65, 0x6c, 0x6c, 0x6f, 0x20, 0x66, 0x72,  // "Hello fr"
        0x6f, 0x6d, 0x20, 0x75, 0x73, 0x65, 0x72, 0x20,  // "om user "
        0x64, 0x6f, 0x6d, 0x61, 0x69, 0x6e, 0x21, 0x0a,  // "domain!\n"
    };

    static_assert(sizeof(g_test_elf) == 166, "Test ELF binary must be exactly 166 bytes");

} // namespace _internal

export {

namespace zxfoundation::exec {

    /// @brief Get the embedded test binary.
    ///
    /// @param[out] data  Set to point to the binary data.
    /// @param[out] size  Set to the size of the binary in bytes.
    auto get_test_binary(const u8*& data, u64& size) noexcept -> void {
        data = _internal::g_test_elf;
        size = sizeof(_internal::g_test_elf);
    }

} // namespace zxfoundation::exec

} // end export
