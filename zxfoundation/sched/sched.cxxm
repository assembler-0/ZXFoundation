/// @file zxfoundation/sched/sched.cxxm
/// @brief Scheduler core — schedule(), tick, init, work-stealing.

export module zxfoundation.sched.sched;
import zxfoundation.sched.sched_fair;
import zxfoundation.sched.sched_idle;
import zxfoundation.sched.sched_domain;
import zxfoundation.domain.domain_types;
import zxfoundation.domain.domain;
import zxfoundation.gate.gate;
import zxfoundation.portal.portal;
import zxfoundation.base.types;
import zxfoundation.base.config;
import zxfoundation.memory.hhdm;
import zxfoundation.sys.printk;
import zxfoundation.sys.syschk;
import zxfoundation.sys.timer_types;
import zxfoundation.sys.timer;
import zxfoundation.sys.time;
import arch.s390x.cpu.lowcore;
import arch.s390x.cpu.percpu_types;
import arch.s390x.cpu.irq;
import arch.s390x.cpu.psw;
import arch.s390x.cpu.processor;
import lib.error;
import lib.format;

extern "C" auto __switch_to_asm(
    zxfoundation::domain::domain* prev,
    zxfoundation::domain::domain* next
) noexcept -> zxfoundation::domain::domain*;

namespace _internal {

    using namespace zxfoundation::domain;
    using namespace zxfoundation::sys::printk;

    static run_queue g_rqs[zxfoundation::base::config::CONFIG_ZX_MAX_CPUS]{};
    static bool g_sched_initialized{false};

    /// @brief Static storage for the BSP scheduler tick timer.
    static zxfoundation::sys::timer::kernel_timer g_bsp_tick_timer{};

    /// @brief Try to steal a domain from the busiest CPU.
    /// @param local_rq  Caller's run_queue (lock held on entry, held on return).
    /// @return Stolen domain, or nullptr.
    auto try_steal_domain_locked(run_queue& local_rq) noexcept -> domain* {
        namespace fair = zxfoundation::sched::fair;

        run_queue* busiest = nullptr;
        u32 max_running = 1;

        for (u32 i = 0; i < zxfoundation::base::config::CONFIG_ZX_MAX_CPUS; ++i) {
            auto& rq = g_rqs[i];
            if (&rq == &local_rq) continue;
            if (!rq.idle) continue;

            if (rq.nr_running > max_running) {
                max_running = rq.nr_running;
                busiest = &rq;
            }
        }

        if (!busiest) return nullptr;

        local_rq.lock.unlock();

        run_queue& first  = (local_rq.cpu_id < busiest->cpu_id) ? local_rq : *busiest;
        run_queue& second = (local_rq.cpu_id < busiest->cpu_id) ? *busiest : local_rq;

        first.lock.lock();
        second.lock.lock();

        domain* stolen = nullptr;
        if (busiest->nr_running > 1) {
            auto* last = busiest->fair_tree.root.node;
            if (last) {
                while (last->right) last = last->right;

                stolen = fair::rb_node_to_domain(last);

                fair::dequeue(*busiest, *stolen);
                stolen->cpu = local_rq.cpu_id;

                stolen->sched.vruntime = local_rq.min_vruntime;
                stolen->sched.deadline = stolen->sched.vruntime +
                    (stolen->sched.slice * 1024 / stolen->sched.weight);
            }
        }

        busiest->lock.unlock();

        return stolen;
    }

} // namespace _internal

export {

namespace zxfoundation::sched {

    using zxfoundation::domain::domain;
    using zxfoundation::domain::domain_id;
    using zxfoundation::domain::domain_flags;
    using zxfoundation::domain::domain_state;
    using zxfoundation::domain::run_queue;

    // ── Re-exports from sub-modules ─────────────────────────────────────

    using domain_ctx::domain_entry_fn;
    using domain_ctx::setup_domain_context;
    using domain_ctx::domain_enter_user;

    /// @brief Get the run_queue for a given CPU.
    [[nodiscard]] auto cpu_rq(u16 cpu_id) noexcept -> run_queue& {
        return _internal::g_rqs[cpu_id];
    }

    /// @brief Get the current CPU's run_queue.
    [[nodiscard]] auto this_rq() noexcept -> run_queue& {
        const auto& pcp = arch::s390x::cpu::lowcore::this_cpu_percpu();
        return _internal::g_rqs[pcp.cpu_id];
    }

    /// @brief Enqueue a domain on its assigned CPU's run queue.
    auto enqueue_domain(domain* d) noexcept -> void {
        auto& rq = cpu_rq(d->cpu);
        const auto flags = arch::s390x::cpu::irq::irq_save_disable();
        rq.lock.lock();
        fair::enqueue(rq, *d);
        rq.lock.unlock();
        arch::s390x::cpu::irq::irq_restore(flags);
    }

    /// @brief Dequeue a domain from its run queue.
    auto dequeue_domain(domain* d) noexcept -> void {
        auto& rq = cpu_rq(d->cpu);
        const auto flags = arch::s390x::cpu::irq::irq_save_disable();
        rq.lock.lock();
        fair::dequeue(rq, *d);
        rq.lock.unlock();
        arch::s390x::cpu::irq::irq_restore(flags);
    }

    // ── Core scheduler ──────────────────────────────────────────────────

    /// @brief Core scheduling function — pick next domain and switch.
    auto schedule() noexcept -> void {
        auto& rq = this_rq();

        const auto flags = arch::s390x::cpu::irq::irq_save_disable();
        rq.lock.lock();

        domain* prev = rq.curr;
        domain* next = nullptr;

        if (prev) {
            prev->flags &= ~domain_flags::need_resched;

            if (prev->state == domain_state::active && !prev->on_rq
                && prev != rq.idle) {
                fair::enqueue(rq, *prev);
            }
        }

        if (rq.nr_running > 0) {
            next = fair::pick_next(rq);
        }

        if (!next && _internal::g_sched_initialized) {
            next = _internal::try_steal_domain_locked(rq);
            if (next) {
                fair::enqueue(rq, *next);
                next = fair::pick_next(rq);
            }
        }

        if (!next) {
            next = rq.idle;
        }

        if (next == prev) {
            rq.lock.unlock();
            arch::s390x::cpu::irq::irq_restore(flags);
            return;
        }

        if (next != rq.idle && next->on_rq) {
            fair::dequeue(rq, *next);
        }

        rq.curr = next;

        if (next->asce.val != 0 && next->asce.val != prev->asce.val) {
            const u64 next_asce_val = next->asce.val;
            arch::s390x::cpu::processor::ctl_load<1, 1>(next_asce_val);
            auto* lc = arch::s390x::cpu::lowcore::get_current();
            lc->user_asce = next_asce_val;
        }

        rq.lock.unlock();

        auto* switched_from = __switch_to_asm(prev, next);

        arch::s390x::cpu::irq::irq_restore(flags);

        if (switched_from &&
            switched_from->state == domain_state::dying &&
            (switched_from->flags & domain_flags::idle) == domain_flags::none) {
            zxfoundation::gate::gate_destroy_for_domain(switched_from->id);
            zxfoundation::portal::portal_destroy_for_domain(switched_from->id);
            zxfoundation::domain::domain_reap(*switched_from);
        }
    }

    // ── Tick / preemption ────────────────────────────────────────────────

    /// @brief Called from the tick handler on each timer interrupt.
    auto scheduler_tick() noexcept -> void {
        if (!_internal::g_sched_initialized) return;

        auto& rq = this_rq();
        rq.lock.lock();

        auto* curr = rq.curr;
        if (!curr || curr == rq.idle) {
            rq.lock.unlock();
            return;
        }

        fair::tick(rq, *curr);
        rq.lock.unlock();
    }

    /// @brief Check if the current domain has need_resched set.
    [[nodiscard]] auto need_resched() noexcept -> bool {
        auto* cur = static_cast<domain*>(
            arch::s390x::cpu::lowcore::current_domain_ptr());
        if (!cur) return false;
        return !!(cur->flags & domain_flags::need_resched);
    }

    /// @brief Called from preempt_enable() when preempt_count drops to 0.
    auto preempt_schedule() noexcept -> void {
        if (!_internal::g_sched_initialized) return;
        if (need_resched()) {
            schedule();
        }
    }

    /// @brief Check if the scheduler has been initialized.
    [[nodiscard]] auto sched_active() noexcept -> bool {
        return _internal::g_sched_initialized;
    }

    // ── Initialization ──────────────────────────────────────────────────

    /// @brief Initialize the scheduler on the BSP (CPU 0).
    auto sched_init() noexcept -> void {
        using namespace _internal;
        using namespace zxfoundation::sys::printk;

        pinfo("sched: initializing scheduler");

        for (u32 i = 0; i < base::config::CONFIG_ZX_MAX_CPUS; ++i) {
            g_rqs[i].cpu_id = static_cast<u16>(i);
        }

        auto* idle_dom = idle::init_idle_domain(0);
        if (!idle_dom) {
            perr("sched: cannot create idle domain");
            return;
        }
        idle_dom->name = "idle/0";

        auto& rq = g_rqs[0];
        rq.idle = idle_dom;
        rq.curr = idle_dom;

        auto& lc = *arch::s390x::cpu::lowcore::get_current();
        lc.current_domain = reinterpret_cast<u64>(idle_dom);
        lc.kernel_stack = idle_dom->kstack_top;
        auto& pcp = arch::s390x::cpu::lowcore::this_cpu_percpu();
        pcp.current_domain = reinterpret_cast<u64>(idle_dom);
        pcp.kernel_stack = idle_dom->kstack_top;

        // Create BSP periodic scheduler tick timer.
        {
            using namespace zxfoundation::sys::timer;
            auto& t = g_bsp_tick_timer;
            t.deadline_tod = arch::s390x::cpu::processor::stck() + TICK_INTERVAL_TOD;
            t.interval_tod = TICK_INTERVAL_TOD;
            t.callback     = [](void*) noexcept -> void {
                zxfoundation::sys::time::tick_advance_wall(TICK_INTERVAL_NS);
                zxfoundation::sched::scheduler_tick();
            };
            t.data         = nullptr;
            t.mode         = timer_mode::periodic;
            (void)timer_add(t);
        }

        g_sched_initialized = true;

        pinfo("sched: idle/0 id={}, scheduler ready", idle_dom->id);
    }

    /// @brief Initialize the scheduler on an AP.
    [[noreturn]] auto sched_init_ap(u16 cpu_id) noexcept -> void {
        using namespace _internal;
        using namespace zxfoundation::sys::printk;

        auto* idle_dom = idle::init_idle_domain(cpu_id);
        if (!idle_dom) {
            zxfoundation::sys::syschk::syschk_fatal(
                lib::kernel_error::from_memory(lib::memory_error::out_of_memory),
                "sched: cannot create AP idle domain for cpu {}",
                cpu_id);
        }
        idle_dom->name = "idle/N";

        auto& rq = g_rqs[cpu_id];
        rq.idle = idle_dom;
        rq.curr = idle_dom;

        auto& lc = *arch::s390x::cpu::lowcore::get_current();
        lc.current_domain = reinterpret_cast<u64>(idle_dom);
        lc.kernel_stack = idle_dom->kstack_top;
        auto& pcp = arch::s390x::cpu::lowcore::this_cpu_percpu();
        pcp.current_domain = reinterpret_cast<u64>(idle_dom);
        pcp.kernel_stack = idle_dom->kstack_top;

        pinfo("sched: cpu{} online, idle id={}", cpu_id, idle_dom->id);

        // Initialize timer subsystem for this AP and create tick timer.
        {
            using namespace zxfoundation::sys::timer;
            timer_init_ap(cpu_id);

            static kernel_timer ap_tick_timers[base::config::CONFIG_ZX_MAX_CPUS]{};
            auto& t = ap_tick_timers[cpu_id];
            t.deadline_tod = arch::s390x::cpu::processor::stck() + TICK_INTERVAL_TOD;
            t.interval_tod = TICK_INTERVAL_TOD;
            t.callback     = [](void*) noexcept -> void {
                zxfoundation::sys::time::tick_advance_wall(TICK_INTERVAL_NS);
                zxfoundation::sched::scheduler_tick();
            };
            t.data         = nullptr;
            t.mode         = timer_mode::periodic;
            (void)timer_add(t);
        }

        // Enter the scheduler idle loop.
        while (true) {
            arch::s390x::cpu::irq::irq_enable();
            arch::s390x::cpu::processor::cpu_relax();
            arch::s390x::cpu::irq::irq_disable();
            schedule();
        }
    }

} // namespace zxfoundation::sched

} // end export
