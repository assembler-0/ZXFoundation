/// @file endian.cxxm
/// @brief Endianness detection and constants

export module zxfoundation.base.endian;

export {

namespace zxfoundation::base {

    /// @brief Enum representing endianness.
    enum class endian {
        little = 0,
        big    = 1,
        native = __BYTE_ORDER__ == __ORDER_LITTLE_ENDIAN__ ? little : big
    };

} // namespace lib

} // end export
